{
  "name": "openlina",
  "version": "0.1.0",
  "description": "Local GUI for managing AI coding assistants — Codex, Claude Code, and more",
  "bin": {
    "openlina": "./bin/openlina.js"
  },
  "files": [
    "bin/",
    "server.js",
    "scripts/",
    ".next/",
    "public/",
    "src/"
  ],
  "scripts": {
    "dev": "node --experimental-sqlite server.js",
    "build": "next build",
    "start": "NODE_ENV=production node --experimental-sqlite server.js",
    "kill": "fuser -k 3747/tcp || true",
    "restart": "npm run kill && npm run dev",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.15.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "next": "^14.2.4",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.3.0",
    "uuid": "^10.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
