# Copy to .env.local and fill in real values before starting the server.

# Admin panel password (the owner types this at /admin/login)
ADMIN_PASSWORD=change-me

# iron-session encryption key — must be at least 32 characters, random
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-32-char-random-string-here
